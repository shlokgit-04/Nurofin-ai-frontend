# === Frontend Environment Variables ===
# For Cloudflare Pages: set these in the Cloudflare dashboard
# For local dev: set in .env.local or export in your shell

# Backend API URL (used by Cloudflare Pages Functions proxy)
# Local dev: http://127.0.0.1:8000
# Production: https://nurofin-ai-backend.onrender.com
BACKEND_URL=http://127.0.0.1:8000

# AI Engine URL (used by Cloudflare Pages Functions proxy)
# Local dev: http://127.0.0.1:8001
# Production: https://ai-engin.onrender.com
AI_ENGINE_URL=http://127.0.0.1:8001

NEXT_PUBLIC_API_URL=https://nurofin-ai-backend.onrender.com
BACKEND_URL=https://nurofin-ai-backend.onrender.com
AI_ENGINE_URL=https://ai-engin.onrender.com